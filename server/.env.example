# ─── Server runtime ───────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Allowed browser origin (the Vite client)
CLIENT_ORIGIN=http://localhost:5173

# ─── Database (matches docker-compose.yml) ─────────────────────────────────────
DATABASE_URL=postgresql://tripu:tripu@localhost:5432/tripu?schema=public

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random value, e.g.:  node -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
JWT_SECRET=replace-me-with-a-long-random-string
# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI engine (server-side ONLY — never expose to the client) ─────────────────
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Default model for itinerary generation (claude-opus-4-8 for the quality toggle)
AI_MODEL=claude-sonnet-4-6
